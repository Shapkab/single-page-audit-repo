{
  "name": "single-page-audit-tool",
  "version": "1.0.0",
  "private": true,
  "description": "Single-page audit tool with Playwright, TypeScript, JSON + Markdown reports, and local artifacts.",
  "type": "module",
  "scripts": {
    "audit": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run test:run"
  },
  "dependencies": {
    "playwright": "^1.53.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.30",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
